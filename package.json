{
  "name": "workout-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "complexity": "eslint --config eslint.complexity.config.js src/",
    "preview": "vite preview",
    "test": "node -r ./e2e/polyfill-crypto-hash.cjs node_modules/.bin/vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "node -r ./e2e/polyfill-crypto-hash.cjs node_modules/.bin/vitest run --project browser",
    "test:watch": "node -r ./e2e/polyfill-crypto-hash.cjs node_modules/.bin/vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-body-highlighter": "^2.0.5",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.12.10",
    "playwright": "^1.58.2",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
